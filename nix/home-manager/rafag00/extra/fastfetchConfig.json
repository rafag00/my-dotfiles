{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "type": "auto",
        "source": "~/nix/home-manager/rafag00/extra/logo.txt",
        "padding": {
            "top": 2,         
            "left": 0,         
            "right": 2         
        },
        "color": {     
            "1": "39",
            "2": "35"
        }
    },
    "display": {
        "separator": "  "
    },
    "modules": [
        { "type": "custom", "format": " " },
        {
            "key": "",
            "type": "title",
            "format": "{user-name}@{host-name}",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "host",
            "format": "{vendor} {family}",
            "keyColor": "35"
        },
        {
            "key": "{icon}",
            "type": "os",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "kernel",
            "keyColor": "35"
        },
        {
            "key": "{icon}",
            "type": "de",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "wm",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "terminal",
            "keyColor": "35"
        },
        {
            "key": "{icon}",
            "type": "shell",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "cpu",
            "showPeCoreCount": true,
            "keyColor": "35"
        },
       {
            "key": "{icon}",
            "type": "gpu",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "disk",
            "folders": "/",
            "keyColor": "35"
        },
        {
            "key": "{icon}",
            "type": "memory",
            "keyColor": "39"
        },
        {
            "key": "{icon}",
            "type": "swap",
            "keyColor": "35"
        },
        { "type": "custom", "format": " " }
    ]
}
